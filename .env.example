# Apex domain for tenant subdomains (wildcard *.sites.letusbuildyourwebsite.com)
NEXT_PUBLIC_ROOT_DOMAIN=sites.letusbuildyourwebsite.com

# Supabase — the NEW project for the platform (separate from ernyst)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — lead notification emails (sender domain must be verified in Resend)
RESEND_API_KEY=
LEADS_FROM_EMAIL="Website Leads <leads@letusbuildyourwebsite.com>"
# Optional: BCC yourself on every lead across all client sites
LEADS_NOTIFY_EMAIL=

# Shared secret for POST /api/revalidate (cache purge after content edits)
REVALIDATE_SECRET=
